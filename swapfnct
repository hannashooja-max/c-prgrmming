#include <stdio.h>
void swap(int x, int y)
{
    int z;
    z = x;      
    x = y;      
    y = z; 
    
    printf("After swap:\n");
    printf("x = %d\n", x);
    printf("y = %d\n", y);
}

int main()
{
    int x, y;
    
    printf("Enter value for x: ");
    scanf("%d", &x);
    
    printf("Enter value for y: ");
    scanf("%d", &y);
    
    printf("\nBefore swap:\n");
    printf("x = %d\n", x);
    printf("y = %d\n\n", y);
    
    swap(x, y);  
    
    return 0;
}
